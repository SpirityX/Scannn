app.post('/api/ai/chat', async (req, res) => {
  const {message, history=[]} = req.body;
  if (!message) return res.status(400).json({error:'Message manquant.'});
  if (!OPENAI_KEY) return res.json({ok:false, error:'Clé OpenAI non configurée.'});
  try {
    const messages = [
      {role:'system', content: SYS_PROMPT + '\nTu peux aussi répondre à des questions générales sur la cybersécurité, les réseaux, les protocoles et les bonnes pratiques IT.'},
      ...history.slice(-10),
      {role:'user', content: message}
    ];
    const res2 = await fetchFn('https://api.openai.com/v1/chat/completions', {
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':`Bearer ${OPENAI_KEY}`},
      body:JSON.stringify({model:'gpt-4o', max_tokens:1500, temperature:0.4, messages})
    });
    const data = await res2.json();
    res.json({ok:true, analysis: data.choices[0].message.content});
  } catch(e) { res.json({ok:false, error:e.message}); }
});

